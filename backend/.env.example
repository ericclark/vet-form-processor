# Local development (SQLite, mock extraction, local file storage)
DATABASE_URL=sqlite+aiosqlite:///./boah.db
DATABASE_URL_SYNC=sqlite:///./boah.db
USE_LOCAL_STORAGE=true
USE_MOCK_EXTRACTION=true
DEBUG=false

# Production / GCP deployment (uncomment and configure)
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/boah
# DATABASE_URL_SYNC=postgresql+psycopg2://user:pass@host:5432/boah
# USE_LOCAL_STORAGE=false
# USE_MOCK_EXTRACTION=false
# GCP_PROJECT_ID=your-gcp-project
# GCP_LOCATION=us-central1
# GEMINI_MODEL=gemini-2.5-pro
# GCS_STAGING_BUCKET=boah-staging
# GCS_RAW_FORMS_BUCKET=boah-raw-forms
# GCS_ARCHIVE_BUCKET=boah-archive
